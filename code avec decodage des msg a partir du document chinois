/*
  ESP32 + MCP2515 — Lecture et decodage des messages CAN du BMS
  selon le document "Protocole de communication CAN"
  IMPORTANT : debit de bus = 250 kbps (impose par le protocole)
*/

#include <SPI.h>
#include <mcp_can.h>

#define CAN_CS_PIN   5
#define CAN_INT_PIN  4
#define CAN_SPEED    CAN_250KBPS
#define CAN_CLOCK    MCP_8MHZ      // mettre MCP_16MHZ si ton module a un quartz 16MHz

MCP_CAN CAN(CAN_CS_PIN);

#define BMS_REQUEST_ID   0x18FF28F4UL

byte bmsRequestData[8] = {0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00};
byte bmsRequestLen = 8;

unsigned long lastRequestTime = 0;
const unsigned long REQUEST_INTERVAL_MS = 1000;

void sendBmsRequest() {
  byte sndStat = CAN.sendMsgBuf(BMS_REQUEST_ID, 1, bmsRequestLen, bmsRequestData);
  if (sndStat == CAN_OK) {
    Serial.println(">> Requete envoyee au BMS (ID 0x18FF28F4)");
  } else {
    Serial.print(">> Echec d'envoi de la requete, code erreur: ");
    Serial.println(sndStat);
  }
}

void printCanFrame(unsigned long id, bool isExtended, byte len, byte *data) {
  char line[110];
  char dataStr[40] = "";
  char temp[5];

  for (int i = 0; i < 8; i++) {
    if (i < len) {
      sprintf(temp, "%02X ", data[i]);
    } else {
      sprintf(temp, "   ");
    }
    strcat(dataStr, temp);
  }

  sprintf(line, "ID: 0x%08lX | %-8s (%2d bits) | DLC: %d | Data: %s",
          id,
          isExtended ? "etendu" : "standard",
          isExtended ? 29 : 11,
          len,
          dataStr);

  Serial.println(line);
}

void decodeBmsMsg1(byte *d) {
  bool cableConnecte   = d[0] & 0x01;
  bool enCharge        = (d[0] >> 1) & 0x01;
  bool sousChargeProf  = (d[0] >> 2) & 0x01;
  bool packPret        = (d[0] >> 3) & 0x01;
  bool contactDecharge = (d[0] >> 4) & 0x01;
  bool contactCharge   = (d[0] >> 5) & 0x01;

  byte soc = d[1];

  int rawCourant = d[2] | (d[3] << 8);
  float courant = (rawCourant - 5000) * 0.1;

  int rawTension = d[4] | (d[5] << 8);
  float tension = rawTension * 0.1;

  byte niveauDefaut = d[6];
  byte codeDefaut = d[7];

  Serial.println("   >> BMS Info #1 (0x18FF28F4)");
  Serial.print("      Cable de charge   : "); Serial.println(cableConnecte ? "connecte" : "non connecte");
  Serial.print("      En charge         : "); Serial.println(enCharge ? "oui" : "non");
  Serial.print("      Sous-charge prof. : "); Serial.println(sousChargeProf ? "oui" : "non");
  Serial.print("      Pack pret         : "); Serial.println(packPret ? "oui" : "non");
  Serial.print("      Contacteur decharge: "); Serial.println(contactDecharge ? "ferme" : "ouvert");
  Serial.print("      Contacteur charge : "); Serial.println(contactCharge ? "ferme" : "ouvert");
  Serial.print("      SOC               : "); Serial.print(soc); Serial.println(" %");
  Serial.print("      Courant pack      : "); Serial.print(courant, 1); Serial.println(" A");
  Serial.print("      Tension totale    : "); Serial.print(tension, 1); Serial.println(" V");
  Serial.print("      Niveau de defaut  : "); Serial.println(niveauDefaut);
  Serial.print("      Code de defaut    : "); Serial.println(codeDefaut);
}

void decodeBmsMsg2(byte *d) {
  int maxCellV = d[0] | (d[1] << 8);
  int minCellV = d[2] | (d[3] << 8);
  int maxTemp  = d[4] - 40;
  int minTemp  = d[5] - 40;
  int rawMaxDischCur = d[6] | (d[7] << 8);
  float maxDischCur = rawMaxDischCur * 0.1;

  Serial.println("   >> BMS Info #2 (0x18FE28F4)");
  Serial.print("      Tension max cellule : "); Serial.print(maxCellV); Serial.println(" mV");
  Serial.print("      Tension min cellule : "); Serial.print(minCellV); Serial.println(" mV");
  Serial.print("      Temp max cellule    : "); Serial.print(maxTemp); Serial.println(" C");
  Serial.print("      Temp min cellule    : "); Serial.print(minTemp); Serial.println(" C");
  Serial.print("      I decharge max autorise: "); Serial.print(maxDischCur, 1); Serial.println(" A");
}

void decodeBmsCellDetail(byte *d, byte pf) {
  int base = (pf - 0xC8) * 4 + 1;
  Serial.print("   >> BMS Tensions cellules (trame PF=0x");
  Serial.print(pf, HEX);
  Serial.println(")");
  for (int i = 0; i < 4; i++) {
    int v = (d[i * 2] << 8) | d[i * 2 + 1];
    Serial.print("      Cellule n.");
    Serial.print(base + i);
    Serial.print(" : ");
    Serial.print(v);
    Serial.println(" mV");
  }
}

void decodeBmsTempDetail(byte *d, byte pf) {
  int base = (pf - 0xB4) * 8 + 1;
  Serial.print("   >> BMS Temperatures (trame PF=0x");
  Serial.print(pf, HEX);
  Serial.println(")");
  for (int i = 0; i < 8; i++) {
    int t = d[i] - 40;
    Serial.print("      Sonde n.");
    Serial.print(base + i);
    Serial.print(" : ");
    Serial.print(t);
    Serial.println(" C");
  }
}

void decodeBmsChargeRequest(byte *d) {
  int rawV = d[0] | (d[1] << 8);
  float vMax = rawV * 0.1;
  int rawI = d[2] | (d[3] << 8);
  float iMax = rawI * 0.1;
  bool stop = d[4] & 0x01;

  Serial.println("   >> BMS Demande de charge (0x18FFE5F4)");
  Serial.print("      Tension max autorisee: "); Serial.print(vMax, 1); Serial.println(" V");
  Serial.print("      Courant max autorise : "); Serial.print(iMax, 1); Serial.println(" A");
  Serial.print("      Commande : "); Serial.println(stop ? "ARRET (protection batterie)" : "Demarrer la charge");
}

void decodeChargerFeedback(byte *d) {
  int rawV = d[0] | (d[1] << 8);
  float vOut = rawV * 0.1;
  int rawI = d[2] | (d[3] << 8);
  float iOut = rawI * 0.1;

  bool defautMateriel  = d[4] & 0x01;
  bool defautTemp      = (d[4] >> 1) & 0x01;
  bool modeBassePuiss  = (d[4] >> 2) & 0x01;
  bool defautTensionIn = (d[4] >> 3) & 0x01;
  bool surintensite    = (d[4] >> 4) & 0x01;
  bool enCharge        = (d[4] >> 5) & 0x01;
  bool defautCommunic  = (d[4] >> 6) & 0x01;
  bool defautBatterie  = (d[4] >> 7) & 0x01;

  Serial.println("   >> Retour Chargeur (0x18FF50E5)");
  Serial.print("      Tension sortie : "); Serial.print(vOut, 1); Serial.println(" V");
  Serial.print("      Courant sortie : "); Serial.print(iOut, 1); Serial.println(" A");
  Serial.print("      Defaut materiel        : "); Serial.println(defautMateriel ? "OUI" : "non");
  Serial.print("      Surchauffe chargeur    : "); Serial.println(defautTemp ? "OUI" : "non");
  Serial.print("      Mode basse puissance   : "); Serial.println(modeBassePuiss ? "OUI" : "non");
  Serial.print("      Defaut tension entree  : "); Serial.println(defautTensionIn ? "OUI" : "non");
  Serial.print("      Surintensite sortie    : "); Serial.println(surintensite ? "OUI" : "non");
  Serial.print("      En charge              : "); Serial.println(enCharge ? "oui" : "non");
  Serial.print("      Defaut communication   : "); Serial.println(defautCommunic ? "OUI" : "non");
  Serial.print("      Defaut connexion batt. : "); Serial.println(defautBatterie ? "OUI" : "non");
}

void decodeMcuMsg1(byte *d) {
  byte position = d[0] & 0x03;
  bool frein     = (d[0] >> 2) & 0x01;
  byte mode      = (d[0] >> 3) & 0x03;
  bool pret      = (d[0] >> 5) & 0x01;
  bool limPuiss  = (d[0] >> 6) & 0x01;

  byte codeDefaut = d[1];
  int vitesseMoteur = d[2] | (d[3] << 8);
  int kmPartiel     = d[4] | (d[5] << 8);
  byte vitesseVehicule = d[6];

  const char* posStr  = (position == 1) ? "avant (D)" : (position == 2) ? "arriere (R)" : "invalide";
  const char* modeStr = (mode == 0) ? "defaut" : (mode == 1) ? "eco" : (mode == 2) ? "sport" : "reserve";

  Serial.println("   >> MCU Info #1 (0x18F560EF)");
  Serial.print("      Position de marche : "); Serial.println(posStr);
  Serial.print("      Frein actif        : "); Serial.println(frein ? "oui" : "non");
  Serial.print("      Mode               : "); Serial.println(modeStr);
  Serial.print("      Controleur pret    : "); Serial.println(pret ? "oui" : "non");
  Serial.print("      Limitation puiss.  : "); Serial.println(limPuiss ? "oui" : "non");
  Serial.print("      Code de defaut MCU : "); Serial.println(codeDefaut);
  Serial.print("      Vitesse moteur     : "); Serial.print(vitesseMoteur); Serial.println(" tr/min");
  Serial.print("      Compteur partiel   : "); Serial.print(kmPartiel * 0.1, 1); Serial.println(" km");
  Serial.print("      Vitesse vehicule   : "); Serial.print(vitesseVehicule); Serial.println(" km/h");
}

void decodeMcuMsg2(byte *d) {
  int vBatt = d[0] | (d[1] << 8);
  int iMoteur = d[2] | (d[3] << 8);
  int tMoteur = d[4] | (d[5] << 8);
  int tCtrl = d[6] | (d[7] << 8);

  Serial.println("   >> MCU Info #2 (0x18FA60EF)");
  Serial.print("      Tension batterie    : "); Serial.print(vBatt * 0.1, 1); Serial.println(" V");
  Serial.print("      Courant moteur      : "); Serial.print(iMoteur * 0.1, 1); Serial.println(" A");
  Serial.print("      Temperature moteur  : "); Serial.print(tMoteur * 0.1, 1); Serial.println(" C");
  Serial.print("      Temp. controleur    : "); Serial.print(tCtrl * 0.1, 1); Serial.println(" C");
}

void decodeMmcMsg(byte *d) {
  byte mode = d[0] & 0x03;
  const char* modeStr = (mode == 0) ? "normal" : (mode == 1) ? "economique" : (mode == 2) ? "sport" : "reserve";
  Serial.println("   >> MMC Info (0x18FF5028)");
  Serial.print("      Mode utilisateur : "); Serial.println(modeStr);
}

void decodeMessage(unsigned long id, bool isExtended, byte len, byte *data) {
  if (!isExtended || len < 1) return;

  byte SA = id & 0xFF;
  byte PS = (id >> 8) & 0xFF;
  byte PF = (id >> 16) & 0xFF;

  switch (id) {
    case 0x18FF28F4: if (len >= 8) decodeBmsMsg1(data); return;
    case 0x18FE28F4: if (len >= 8) decodeBmsMsg2(data); return;
    case 0x18FFE5F4: if (len >= 5) decodeBmsChargeRequest(data); return;
    case 0x18FF50E5: if (len >= 5) decodeChargerFeedback(data); return;
    case 0x18F560EF: if (len >= 7) decodeMcuMsg1(data); return;
    case 0x18FA60EF: if (len >= 8) decodeMcuMsg2(data); return;
    case 0x18FF5028: if (len >= 1) decodeMmcMsg(data); return;
  }

  if (SA == 0xF4 && PS == 0x28) {
    if (PF >= 0xC8 && PF <= 0xF8 && len >= 8) { decodeBmsCellDetail(data, PF); return; }
    if (PF >= 0xB4 && PF <= 0xC7 && len >= 8) { decodeBmsTempDetail(data, PF); return; }
  }

  Serial.println("   (message non reconnu dans le protocole)");
}

void setup() {
  Serial.begin(115200);
  while (!Serial) { ; }

  pinMode(CAN_INT_PIN, INPUT);
  Serial.println("Initialisation du module MCP2515...");

  while (CAN.begin(MCP_ANY, CAN_SPEED, CAN_CLOCK) != CAN_OK) {
    Serial.println("Echec de l'initialisation du MCP2515, nouvelle tentative...");
    delay(500);
  }

  CAN.setMode(MCP_NORMAL);
  Serial.println("MCP2515 initialise avec succes (250 kbps). En attente de messages CAN...");
  Serial.println("-----------------------------------------------------------");
}

void loop() {
  if (millis() - lastRequestTime >= REQUEST_INTERVAL_MS) {
    sendBmsRequest();
    lastRequestTime = millis();
  }

  if (CAN.checkReceive() == CAN_MSGAVAIL) {
    long unsigned int rxId;
    unsigned char len = 0;
    unsigned char rxBuf[8] = {0, 0, 0, 0, 0, 0, 0, 0};

    CAN.readMsgBuf(&rxId, &len, rxBuf);

    if (len > 8) len = 8;

    bool isExtended = (rxId & 0x80000000) != 0;
    unsigned long idValue = isExtended ? (rxId & 0x1FFFFFFF) : (rxId & 0x7FF);

    printCanFrame(idValue, isExtended, len, rxBuf);
    decodeMessage(idValue, isExtended, len, rxBuf);
    Serial.println();

    delay(100);
  }
}
